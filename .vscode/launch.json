{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Debugger Angular",
            "url": "http://localhost:4200",
            "sourceMaps": true,
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": [
                "--disable-blink-features=AutomationControlled"
            ]
        },
        {
            "type": "pwa-chrome",
            "request": "attach",
            "name": "Attach to Chrome",
            "port": 9222,
            "sourceMaps": true,
            "webRoot": "${workspaceFolder}"
        }
    ]
}